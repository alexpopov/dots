#!/usr/bin/env bash
# llm-open-nvr: Open a file in the neovim instance for the current tmux window.
# Designed for use by LLM agents (Claude Code, etc.) that run inside tmux
# but need to open files in the user's neovim editor.
#
# Uses native nvim --server/--remote (no neovim-remote dependency).
#
# Usage: llm-open-nvr [options] <file> [file2 ...]
# Options:
#   --tab       Open in a new tab (default)
#   --split     Open in a horizontal split
#   --vsplit    Open in a vertical split
#   --diff      Open files in diff mode
#   --send <keys>  Send keystrokes to neovim (e.g. --send ':w<CR>')
#   --expr <expr>  Evaluate neovim expression and print result
#   --line <n>     Jump to line number (e.g. --line 42 file.py)

set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "Usage: llm-open-nvr [--tab|--split|--vsplit] <file> [file2 ...]" >&2
    exit 1
fi

get_socket() {
    if [[ -z "${TMUX:-}" ]]; then
        echo "Error: Not inside tmux" >&2
        exit 1
    fi
    local wname
    wname=$(tmux display-message -p '#W')
    local sock="$HOME/.local/state/nvr-$wname"
    if [[ ! -S "$sock" ]]; then
        echo "Error: No nvr socket at $sock. Ask the user to run 'nvr' in the '$wname' tmux window." >&2
        exit 1
    fi
    echo "$sock"
}

case "${1:-}" in
    --tab)
        shift
        socket_path=$(get_socket)
        exec nvim --server "$socket_path" --remote-tab "$@"
        ;;
    --split)
        shift
        socket_path=$(get_socket)
        for f in "$@"; do
            nvim --server "$socket_path" --remote-send "<C-\\><C-N>:split $(printf '%q' "$f")<CR>"
        done
        exit 0
        ;;
    --vsplit)
        shift
        socket_path=$(get_socket)
        for f in "$@"; do
            nvim --server "$socket_path" --remote-send "<C-\\><C-N>:vsplit $(printf '%q' "$f")<CR>"
        done
        exit 0
        ;;
    --diff)
        shift
        socket_path=$(get_socket)
        if [[ $# -lt 2 ]]; then echo "Error: --diff requires two files" >&2; exit 1; fi
        nvim --server "$socket_path" --remote-send "<C-\\><C-N>:tabnew $1 | diffthis | vsplit $2 | diffthis<CR>"
        exit 0
        ;;
    --send)
        shift
        if [[ $# -eq 0 ]]; then echo "Error: --send requires keys argument" >&2; exit 1; fi
        socket_path=$(get_socket)
        exec nvim --headless --server "$socket_path" --remote-send "$1"
        ;;
    --expr)
        shift
        if [[ $# -eq 0 ]]; then echo "Error: --expr requires expression argument" >&2; exit 1; fi
        socket_path=$(get_socket)
        exec nvim --headless --server "$socket_path" --remote-expr "$1"
        ;;
    --line)
        shift
        if [[ $# -lt 2 ]]; then echo "Error: --line requires <n> <file>" >&2; exit 1; fi
        line_num="$1"; shift
        socket_path=$(get_socket)
        nvim --server "$socket_path" --remote-tab "$1"
        exec nvim --server "$socket_path" --remote-send "<C-\\><C-N>:${line_num}<CR>"
        ;;
    -*)
        echo "Error: Unknown option $1" >&2
        exit 1
        ;;
    *)
        # Default: open in new tab
        socket_path=$(get_socket)
        exec nvim --server "$socket_path" --remote-tab "$@"
        ;;
esac
