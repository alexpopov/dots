#!/usr/bin/env bash
# Launch `claude` with an interactively-chosen subset of MCP servers.
# Definitions live in $CLAUDE_MCP_DEFINITIONS (default: ~/.config/claude-mcp/servers.json),
# a JSON object mapping server name -> server config (same shape as the value side
# of `mcpServers`). Selected servers are written to a temp file and passed to
# `claude --strict-mcp-config --mcp-config`, so nothing else leaks in.
#
# If the current project has a local `.mcp.json` (cwd, else git root), its servers
# are offered as ONE extra choice. Picking it merges them all in alongside the
# global picks — necessary because --strict-mcp-config otherwise drops the
# project's own MCP config (e.g. a repo's `unity` server).

set -euo pipefail

DEFINITIONS="${CLAUDE_MCP_DEFINITIONS:-$HOME/.config/claude-mcp/servers.json}"

# Resolve this script's real location (it may be symlinked onto PATH, e.g. via
# ~/.local/bin/scripts) so we can find sibling repo assets like the ponytail
# persona ruleset that lives in the agent-orchestra-wizard skill.
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
    _dir=$(cd -P "$(dirname "$_src")" && pwd)
    _src=$(readlink "$_src")
    [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_DIR=$(cd -P "$(dirname "$_src")" && pwd)
PONYTAIL_RULESET="$SCRIPT_DIR/../../config/claude/skills/agent-orchestra-wizard/ponytail/ruleset.txt"

if [[ ! -f "$DEFINITIONS" ]]; then
    echo "claude-with: definitions file not found: $DEFINITIONS" >&2
    exit 1
fi

available=$(jq -r 'keys[]' "$DEFINITIONS")
if [[ -z "$available" ]]; then
    echo "claude-with: no servers defined in $DEFINITIONS" >&2
    exit 1
fi

# Discover a project-local .mcp.json (cwd first, then the git root) and offer its
# servers as a single bundled choice rather than individually.
PROJECT_MCP=""
if [[ -f .mcp.json ]]; then
    PROJECT_MCP="$(pwd)/.mcp.json"
elif git_root=$(git rev-parse --show-toplevel 2>/dev/null) && [[ -f "$git_root/.mcp.json" ]]; then
    PROJECT_MCP="$git_root/.mcp.json"
fi

LOCAL_LABEL=""
if [[ -n "$PROJECT_MCP" ]]; then
    local_names=$(jq -r '(.mcpServers // {}) | keys | join(", ")' "$PROJECT_MCP" 2>/dev/null || true)
    [[ -n "$local_names" ]] && LOCAL_LABEL="[project .mcp.json] $local_names"
fi

NONE_LABEL="[none]"
choices="$available"$'\n'"$NONE_LABEL"
[[ -n "$LOCAL_LABEL" ]] && choices=$(printf '%s\n%s' "$LOCAL_LABEL" "$choices")

# Offer the ponytail persona as an opt-in list item at the END (only if its
# ruleset exists). Picking it enables the anti-overengineering persona via
# SessionStart + SubagentStart hooks — so it survives delegation into subagents.
PONYTAIL_LABEL="[persona] ponytail"
[[ -f "$PONYTAIL_RULESET" ]] && choices=$(printf '%s\n%s' "$choices" "$PONYTAIL_LABEL")

selected=$(printf '%s\n' "$choices" | gum choose --no-limit --header "MCP servers for this session" || true)

# Pull special labels out of the selection.
want_none=false
want_local=false
want_ponytail=false
if grep -qxF "$NONE_LABEL" <<< "$selected"; then
    want_none=true
fi
if [[ -n "$LOCAL_LABEL" ]] && grep -qxF "$LOCAL_LABEL" <<< "$selected"; then
    want_local=true
fi
if grep -qxF "$PONYTAIL_LABEL" <<< "$selected"; then
    want_ponytail=true
fi

if [[ -z "${selected//[[:space:]]/}" ]]; then
    echo "claude-with: no servers selected — did you forget to hit space?" >&2
    exit 1
fi

if [[ "$want_none" == true ]]; then
    config='{"mcpServers": {}}'
else
    selected=$(grep -vxF "$LOCAL_LABEL" <<< "$selected" 2>/dev/null | grep -vxF "$PONYTAIL_LABEL" 2>/dev/null || true)
    keys_json=$(printf '%s\n' "$selected" | jq -R . | jq -s 'map(select(length > 0))')
    config=$(jq --argjson keys "$keys_json" '{mcpServers: with_entries(select(.key as $k | $keys | index($k)))}' "$DEFINITIONS")

    # Merge the project-local servers in if chosen (project keys win on collision).
    if [[ "$want_local" == true ]]; then
        config=$(printf '%s' "$config" | jq --slurpfile loc "$PROJECT_MCP" '.mcpServers += ($loc[0].mcpServers // {})')
    fi
fi

# Substitute ${VAR} references in the assembled config (e.g. NOTION_TOKEN_*).
# Source a tokens file first so we don't depend on the parent shell sourcing it.
TOKENS_FILE="${CLAUDE_MCP_TOKENS:-$HOME/.config/bash/private/mcp_tokens.sh}"
[[ -f "$TOKENS_FILE" ]] && source "$TOKENS_FILE"

# Pure-bash substitution: portable (no envsubst dep on Fedora minimal etc).
# Tokens are assumed JSON-safe (no quotes/backslashes); fine for Notion's ntn_*.
for var in $(grep -oE '\$\{[A-Z_][A-Z0-9_]*\}' <<< "$config" | sed -E 's/[$\{\}]//g' | sort -u); do
    [[ -z "${!var:-}" ]] && echo "claude-with: warning: \$$var is unset" >&2
    config="${config//\$\{$var\}/${!var:-}}"
done

tmp=$(mktemp "${TMPDIR:-/tmp}/claude-mcp.XXXXXX").json
printf '%s\n' "$config" > "$tmp"

# Extract --yolo and drop any literal "claude" arg (any position) before
# forwarding, so an existing invocation can be prefixed verbatim, e.g.
# `claude-with claude --resume <id>` or `claude-with --yolo claude --resume <id>`.
yolo=false
rest=()
for arg in "$@"; do
    case "$arg" in
        --yolo) yolo=true ;;
        claude) ;;
        *) rest+=("$arg") ;;
    esac
done

extra_flags=()
[[ "$yolo" == true ]] && extra_flags+=(--dangerously-skip-permissions)

# Ponytail persona: inject the ruleset at SessionStart AND SubagentStart (the
# latter is what carries it into delegated subagents) via an extra --settings
# file. Merges with the user's normal settings; doesn't replace them.
if [[ "$want_ponytail" == true ]]; then
    ponytail_settings=$(mktemp "${TMPDIR:-/tmp}/claude-ponytail.XXXXXX").json
    jq -n --arg cmd "cat \"$PONYTAIL_RULESET\"" '{
        hooks: {
            SessionStart:  [ { hooks: [ { type: "command", command: $cmd } ] } ],
            SubagentStart: [ { hooks: [ { type: "command", command: $cmd } ] } ]
        }
    }' > "$ponytail_settings"
    extra_flags+=(--settings "$ponytail_settings")
fi

exec claude --strict-mcp-config --mcp-config "$tmp" "${extra_flags[@]+"${extra_flags[@]}"}" "${rest[@]+"${rest[@]}"}"
