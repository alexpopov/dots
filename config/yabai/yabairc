# the scripting-addition must be loaded manually if
# you are running yabai on macOS Big Sur. Uncomment
# the following line to have the injection performed
# when the config is executed during startup.
#
# for this to work you must configure sudo such that
# it will be able to run the command without password

# sudo yabai --load-sa
# yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"


# NOTE: read the wiki if you update yabai, particularly regarding visudo and updating the hash


# Spawn new windows bottom or right
yabai -m config window_placement second_child

# focus
yabai -m config mouse_follows_focus on
yabai -m config auto_balance on

# Padding
padding=8
yabai -m config top_padding    $padding
yabai -m config bottom_padding $padding
yabai -m config left_padding   $padding
yabai -m config right_padding  $padding
yabai -m config window_gap     $padding

# This disabled/enables certain apps from being managed implicitly:
yabai_utils.sh style condensed
yabai_utils.sh manage less

# Permenantly off list:
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension)s|AutoFill|Se(arch|curity)|Privacy|Advance)$" manage=off
yabai -m rule --add label="Finder" app="^Finder$" manage=off
yabai -m rule --add label="System Preferences" app="^System Preferences$" title=".*" manage=off
yabai -m rule --add label="System Settings" app="^System Settings$" title=".*" manage=off
yabai -m rule --add app="System Information" manage=off
yabai -m rule --add label="App Store" app="^App Store$" manage=off
yabai -m rule --add label="Activity Monitor" app="^Activity Monitor$" manage=off
yabai -m rule --add label="Calculator" app="^Calculator$" manage=off
yabai -m rule --add label="Dictionary" app="^Dictionary$" manage=off
yabai -m rule --add label="Software Update" title="Software Update" manage=off
yabai -m rule --add label="About This Mac" app="System Information" title="About This Mac" manage=off
for app in \
    "Karabiner-Elements" \
    "QuickTime Player" \
    "Captin" \
    "Cisco" \
    "Cisco Secure Client" \
    "Choosy.*" \
    "Bartender.*" \
    "GeoTag" \
    "Google Drive" \
    "Calendar" \
    "Managed Software Centre" \
    "Archive Utility" \
    ".*sicht" \
    "Steam" \
    "Paradox Launcher" \
    "Problem Reporter" \
    "FaceTime" \
    "Rocket" \
    "Meta Quest Remote Desktop" \
    "Digital Colo(u)?r Meter" \
    "Android Studio" \
    "Calibre" \
    "Maccy" \
    "Keymapp" \
    "Buckets" \
    "Logic Pr.*" \
    "Hammerspoon" \
    "SilverFast 9" \
    "Final Cut Pro" \
    "GarageBand" \
    "Alfred.*" \
    "Shortcat.*" \
    "Magic Island" \
    "Santa" \
    "Unity" \
    "Gmail" \
    "DaisyDisk" \
    "Tailscale" \
    "darktable" \
    "EOS Utility 3" \
    "Developer" \
    "Xcode" \
; do
    yabai -m rule --add app="$app" manage=off
done

# Native-tab apps: tabs appear as new windows to yabai, which disrupts
# BSP layout and destroys stacks. Finder is unmanaged by default.
# For Ghostty: first window is managed normally; subsequent windows on
# the same space (tabs) are floated to avoid layout disruption.
yabai -m signal --add label=ghostty_tab_fix app='^Ghostty$' event=window_created action='
  count=$(yabai -m query --windows | jq "[.[] | select(.app == \"Ghostty\" and .\"is-floating\" == false)] | length")
  if [ "$count" -gt 1 ]; then
    yabai -m window $YABAI_WINDOW_ID --toggle float 2>/dev/null
  fi
'


# Apply all rules
yabai -m rule --apply

# find apps like this:
# yabai -m query --windows | jq '.[] | select( .app == "Numbers" )'

# We turn this on after all the rules, so that it doesn't temporarily
# manage a bunch of windows it has no business managing
yabai -m config layout bsp

