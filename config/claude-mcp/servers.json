{
  "things": {
    "command": "uvx",
    "args": ["things-mcp"]
  },
  "notion": {
    "type": "http",
    "url": "https://mcp.notion.com/mcp"
  },
  "notion-wife": {
    "command": "npx",
    "args": ["-y", "@notionhq/notion-mcp-server"],
    "env": {
      "NOTION_TOKEN": "${NOTION_TOKEN_WIFE}"
    }
  }
}
